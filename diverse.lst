12C9: C8                    rz
12CA: 23                    inx  h
12CB: 4E                    mov  c, m                        ; target addr low
12CC: 23                    inx  h
12CD: 46                    mov  b, m                        ; target addr high
12CE: 02                    stax b                           ; [BC] = value
12CF: 23                    inx  h
