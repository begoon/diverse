0000:                       org  0000h
                            section diverse

                    ; ---- RK86 monitor ROM entry points (F800h-FFFFh) ----
                    ; Public jump-table slots are documented in ../rk86-js-kit/info/RK86.md
                    ; and in the monitor source at ../rk86-monitor/monitor.asm. FD27h is
                    ; the internal SOUND routine (see CLAUDE.md); FAE0h is the tail of
                    ; entry_video (status poll + DMA setup), reused to inject a custom
                    ; SCN4 byte while keeping the rest of the monitor's video init.
                    ; ---- RK86 video memory ----
                    ; Video RAM: 30 rows × 78 cols = 2340 bytes at 76D0h..7FF4h.
                    ; Address of cell (row, col) = video_memory + row*video_stride + col.
=76D0               video_memory     equ 76D0h      ; start of video RAM
=004E               video_stride     equ 78         ; bytes per row (= chars per row)
=77C2               game_area_tl     equ video_memory + 3*video_stride + 8    ; 77C2h -- top-left of 64x25 text window

=F803               rom_getc         equ 0F803h     ; GETC     -- blocking keyboard read; A = key code
=F809               rom_putc         equ 0F809h     ; PUTC     -- print char; C = character
=F815               rom_hexb         equ 0F815h     ; HEXB     -- print A as two hex digits
=F818               rom_puts         equ 0F818h     ; PUTS     -- print NUL-terminated string at HL
=F81B               rom_scan_kbd     equ 0F81Bh     ; SCAN_KBD -- raw matrix scan; A = FFh/FEh/code
=F82D               rom_video        equ 0F82Dh     ; VIDEO    -- reinitialize CRT controller
=F830               rom_getlim       equ 0F830h     ; GETLIM   -- HL = memory limit
=F86C               rom_prompt_loop  equ 0F86Ch     ; PROMPT   -- warm restart to monitor prompt
=FAE0               rom_video_tail   equ 0FAE0h     ; tail of entry_video: status poll + DMA setup
=FD27               rom_sound        equ 0FD27h     ; SOUND    -- beep (B=duration, C=half-period)

0000:               loc_0000:
0000: C3 F0 0B              jmp  main
                    ; ---- Game-local trampolines into the monitor ROM. These 3-byte jmps
                    ; give the game a compact "vector table" at the low end of its address
                    ; space so most call sites can fit a 2-byte `rst n` trampoline pattern
                    ; during hand-assembly. Each slot is reachable via CALL <offset>.
0003:               monitor_scan_kbd:                       ; offset=0003h
0003: C3 1B F8              jmp  rom_scan_kbd
0006:               monitor_putc:                           ; offset=0006h
0006: C3 09 F8              jmp  rom_putc
0009:               monitor_puts:                           ; offset=0009h
0009: C3 18 F8              jmp  rom_puts
000C:               monitor_hexb:                           ; offset=000Ch
000C: C3 15 F8              jmp  rom_hexb
000F:               monitor_getlim:                         ; offset=000Fh
000F: C3 30 F8              jmp  rom_getlim
0012:               monitor_prompt:                         ; offset=0012h
0012: C3 6C F8              jmp  rom_prompt_loop
0015:               monitor_beep:                           ; offset=0015h
0015: C3 27 FD              jmp  rom_sound
                    ; ---- Game state variables at 0018h..003Ch ----
                    ; Bytes 0018h..003Ah are zeroed on every new game by the init loop at
                    ; loc_0247; the "initial" byte values shown here are effectively don't-care
                    ; since they get overwritten before first use. 003Bh/003Ch persist across
                    ; games (beep frequency ramp and РУС/ЛАТ case mask).
                    ;
                    ; Screen coordinates follow the mapping in xy_to_vaddr:
                    ;   video_addr = 77C2h + (24 - y) * 78 + x
                    ; y = 1 is bottom row of the game field, y = 24 is top; x = 1 is leftmost.

0018:               player_x:               ; offset 0018h -- player turret column (1..57)
0018: 56                    db   56h
0019:               saboteur_x:             ; offset 0019h -- flying diversant column (1..3Ch)
0019: 04                    db   04h
001A:               climber_x:              ; offset 001Ah -- climbing diversant column (0 = none)
001A: 59                    db   59h
001B:               torpedo_x:              ; offset 001Bh -- player torpedo column
001B: 04                    db   04h
001C:               ufo_x:                  ; offset 001Ch -- martian UFO column
001C: 5C                    db   5Ch
001D:               player_y:               ; offset 001Dh -- player row (2..23)
001D: 04                    db   04h
001E:               saboteur_y:             ; offset 001Eh -- flying diversant row
001E: 61                    db   61h
001F:               climber_y:              ; offset 001Fh -- climbing diversant row
001F: 04                    db   04h
0020:               torpedo_y:              ; offset 0020h -- player torpedo row
0020: 69                    db   69h
0021:               ufo_y:                  ; offset 0021h -- martian UFO row
0021: 04                    db   04h
0022:               saboteur_active:        ; offset 0022h -- 1 = flying diversant on screen
0022: 8B                    db   8Bh
0023:               saboteur_timer:         ; offset 0023h -- frames until next diversant step
0023: 04                    db   04h
0024:               kbd_debounce:           ; offset 0024h -- ignore repeat input while > 0
0024: 8E                    db   8Eh
0025:               climber_timer:          ; offset 0025h -- frames until climber moves up a row
0025: 04                    db   04h
0026:               torpedo_timer:          ; offset 0026h -- frames until torpedo moves one cell
0026: 9A                    db   9Ah
0027:               ufo_timer:              ; offset 0027h -- frames until UFO animation tick
0027: 04                    db   04h
0028:               saboteur_dir:           ; offset 0028h -- 1 = moving left, 2 = moving right
0028: 9E                    db   9Eh
0029:               climber_active:         ; offset 0029h -- 1 = landed diversant climbing up
0029: 04                    db   04h
002A:               unused_002A:            ; offset 002Ah -- zeroed by init, never read
002A: A7                    db   0A7h
002B:               score_lo:               ; offset 002Bh -- BCD, low two digits of score
002B: 04                    db   04h
002C:               score_hi:               ; offset 002Ch -- BCD, high two digits of score
002C: BF                    db   0BFh
002D:               diversants_landed:      ; offset 002Dh -- BCD; game over at 16 (10h) landed
002D: 04                    db   04h
002E:               saved_climber_x:        ; offset 002Eh -- snapshot of climber_x for redraw
002E: ED                    db   0EDh
002F:               score_positive:         ; offset 002Fh -- 1 = positive score, 0 = "debt"
002F: 04                    db   04h
0030:               rng_state:              ; offset 0030h -- PRNG seed (see rng_next)
0030: 01                    db   01h
0031:               unused_0031:            ; offset 0031h -- unused
0031: 05                    db   05h
0032:               torpedo_active:         ; offset 0032h -- 1 = torpedo in flight
0032: 33                    db   33h
0033:               autotarget_on:          ; offset 0033h -- 1 = auto-targeting bonus awarded
0033: 01                    db   01h
0034:               hit_counter:            ; offset 0034h -- raw kill count; autotarget at 32h
0034: 3F                    db   3Fh
0035:               score_delta_lo:         ; offset 0035h -- BCD bonus added by score_add
0035: 05                    db   05h
0036:               score_delta_hi:         ; offset 0036h
0036: 45                    db   45h
0037:               score_penalty_lo:       ; offset 0037h -- BCD penalty subtracted by score_sub
0037: 05                    db   05h
0038:               score_penalty_hi:       ; offset 0038h
0038: 49                    db   49h
0039:               ufo_active:             ; offset 0039h -- 1 = UFO on screen
0039: 05                    db   05h
003A:               ufo_anim_phase:         ; offset 003Ah -- 0..6, selects UFO glyph pattern
003A: 4F                    db   4Fh
003B:               shoot_beep_freq:        ; offset 003Bh -- frequency ramp for shoot beep
003B: 05                    db   05h
003C:               letter_case_mask:       ; offset 003Ch -- 20h/00h, xor'd with letter key codes
003C: 20                    db   20h
                    ; Reinitialize the К580ВГ75 CRT controller to 78x30 text mode and
                    ; hand off to the monitor's tail to finish DMA/buffer setup. The
                    ; Reset command (00h on C001h) takes four parameter bytes on C000h,
                    ; then Start Display (27h on C001h) re-enables output.
                    ;
                    ; vs the monitor's stock 93h SCN4, this one swaps the cursor to a
                    ; non-blinking underline (so there's no 500 ms blink during play).
003D:               video_init:                             ; offset 003Dh
003D: E5                    push h
003E: 21 01 C0              lxi  h, 0C001h
0041: 36 00                 mvi  m, 00h              ; command: RESET (4 SCN params follow)
0043: 2B                    dcx  h
0044: 36 4D                 mvi  m, 4Dh              ; SCN1: 78 chars/row (H = 77)
0046: 36 1D                 mvi  m, 1Dh              ; SCN2: 30 rows/frame (V = 29, VR = 0)
0048: 36 99                 mvi  m, 99h              ; SCN3: 10 lines/row, underline at line 9
004A: 36 F3                 mvi  m, 0F3h             ; SCN4: L=1 non-offset, F=1 non-transparent,
                                                     ;       C=11 non-blinking underline cursor,
                                                     ;       Z=3 horizontal retrace = 8 char clocks
004C: 23                    inx  h
004D: 36 27                 mvi  m, 27h              ; command: START DISPLAY (begin DMA fetch)
004F: C3 E0 FA              jmp  rom_video_tail      ; monitor tail: program DMA + buffer pointers
                    ; Redraw the score line: "OCHKI : HHLL" where HHLL is the 2-byte BCD
                    ; score (score_hi, score_lo). Cursor is parked at row 24, col 34 by
                    ; the embedded ESC-Y sequence in str_ochki.
0052:               draw_score:                             ; offset 0052h
0052: 21 64 00              lxi  h, str_ochki
0055: CD 09 00              call monitor_puts
0058: 2A 2B 00              lhld score_lo                   ; L = score_lo, H = score_hi
005B: 7C                    mov  a, h
005C: CD 0C 00              call monitor_hexb
005F: 7D                    mov  a, l
0060: CD 0C 00              call monitor_hexb
0063: C9                    ret
0064:               str_ochki:                              ; offset 0064h
0064: 1B 59 38 42           db   1Bh, 'Y', 38h, 42h       ; ESC Y row=24 col=34
0068: 6F 7E 6B 69           db   'o~ki : ', 00h           ; "OCHKI :" -- points :
006C: 20 3A 20 00
                    ; Draw the "DIVERSANTY : " label at row 24, col 10. diversants_landed
                    ; is printed as a two-hex-digit BCD number separately after this call.
0070:               draw_diversants_label:                  ; offset 0070h
0070: 21 77 00              lxi  h, str_diversanty
0073: CD 09 00              call monitor_puts
0076: C9                    ret
0077:               str_diversanty:                         ; offset 0077h
0077: 1B 59 38 2A           db   1Bh, 'Y', 38h, 2Ah       ; ESC Y row=24 col=10
007B: 64 69 77 65           db   'diwersanty : ', 00h     ; "DIVERSANTY :" -- saboteurs :
007F: 72 73 61 6E
0083: 74 79 20 3A
0087: 20 00
                    ; Show the "ONI VAS UNICHTOZHILI / UPLATITE 15 KOPEEK" game-over
                    ; message at row 16, col 12. Shown when diversants_landed reaches 16.
0089:               show_game_over:                         ; offset 0089h
0089: 21 90 00              lxi  h, str_game_over
008C: CD 09 00              call monitor_puts
008F: C9                    ret
0090:               str_game_over:                          ; offset 0090h
0090: 1B 59 30 2C           db   1Bh, 'Y', 30h, 2Ch       ; ESC Y row=16 col=12
0094: 6F 6E 69 20           db   'oni was uni~tovili !!!', 0Dh, 0Ah    ; "ONI VAS UNICHTOZHILI !!!" CR LF -- they destroyed you !!!
0098: 77 61 73 20
009C: 75 6E 69 7E
00A0: 74 6F 76 69
00A4: 6C 69 20 21
00A8: 21 21 0D 0A
00AC: 75 70 6C 61           db   'uplatite 15 kopeek', 00h             ; "UPLATITE 15 KOPEEK" -- pay 15 kopecks
00B0: 74 69 74 65
00B4: 20 31 35 20
00B8: 6B 6F 70 65
00BC: 65 6B 00
                    ; Map game coordinates (B=x, C=y) to a video RAM address in HL.
                    ;   hl = 77C2h + (18h - y) * 4Eh + x
                    ; 77C2h is the top-left of the monitor's 64x25 text window and 4Eh=78
                    ; is the row stride. The (18h - y) inversion makes y=1 the bottom of
                    ; the play field and y=24 the top.
00BF:               xy_to_vaddr:                            ; offset 00BFh
00BF: C5                    push b
00C0: D5                    push d
00C1: F5                    push psw
00C2: 21 C2 77              lxi  h, game_area_tl            ; 77C2h -- top-left of 64x25 text window
00C5: 3E 18                 mvi  a, 18h                     ; flip y: a = 24 - y
00C7: 91                    sub  c
00C8: 4F                    mov  c, a
00C9: 0C                    inr  c                          ; pre-increment for dcr/jz loop
00CA: 11 4E 00              lxi  d, video_stride            ; 004Eh -- bytes per row
00CD:               loc_00CD:
00CD: 0D                    dcr  c
00CE: CA D5 00              jz   loc_00D5
00D1: 19                    dad  d                          ; hl += 78 per row
00D2: C3 CD 00              jmp  loc_00CD
00D5:               loc_00D5:
00D5: 58                    mov  e, b                       ; d=0 from lxi above; de = x
00D6: 19                    dad  d                          ; hl += x
00D7: F1                    pop  psw
00D8: D1                    pop  d
00D9: C1                    pop  b
00DA: C9                    ret
                    ; Draw the 3-cell player turret glyph at HL: "* ^ *" (asterisk, arrow
                    ; up, asterisk). HL must be xy_to_vaddr(player_x, player_y).
00DB:               draw_turret:                            ; offset 00DBh
00DB: 36 2A                 mvi  m, 2Ah                     ; '*'
00DD: 23                    inx  h
00DE: 36 0B                 mvi  m, 0Bh                     ; arrow up
00E0: 23                    inx  h
00E1: 36 2A                 mvi  m, 2Ah                     ; '*'
00E3: C9                    ret
                    ; Draw the 3-cell flying diversant glyph at HL (▞▞▖).
00E4:               draw_saboteur:                          ; offset 00E4h
00E4: 36 12                 mvi  m, 12h
00E6: 23                    inx  h
00E7: 36 12                 mvi  m, 12h
00E9: 23                    inx  h
00EA: 36 10                 mvi  m, 10h
00EC: C9                    ret
                    ; Erase 6 consecutive screen cells starting at HL-1. Used to clear a
                    ; 3-cell sprite plus one-cell margins on either side after movement.
00ED:               clear_6_cells:                          ; offset 00EDh
00ED: 2B                    dcx  h
00EE: 36 20                 mvi  m, 20h
00F0: 23                    inx  h
00F1: 36 20                 mvi  m, 20h
00F3: 23                    inx  h
00F4: 36 20                 mvi  m, 20h
00F6: 23                    inx  h
00F7: 36 20                 mvi  m, 20h
00F9: 23                    inx  h
00FA: 36 20                 mvi  m, 20h
00FC: 23                    inx  h
00FD: 36 20                 mvi  m, 20h
00FF: C9                    ret
                    ; Return a pseudo-random byte in B in the range 0Fh..17h, i.e. a value
                    ; suitable as a screen row index. Algorithm: step B forward (rng_state)
                    ; times through a 0Eh..17h cycle, then save the result + 2Fh as the
                    ; next seed. Used to place flying diversants at random rows.
0100:               rng_next:                               ; offset 0100h
0100: F5                    push psw
0101: C5                    push b
0102: 3A 30 00              lda  rng_state
0105: 4F                    mov  c, a                       ; c = seed steps
0106: 06 0E                 mvi  b, 0Eh
0108:               loc_0108:
0108: 78                    mov  a, b
0109: FE 18                 cpi  18h                        ; wrap 18h back to 0Fh
010B: C2 10 01              jnz  loc_0110
010E: 06 0E                 mvi  b, 0Eh
0110:               loc_0110:
0110: 04                    inr  b
0111: 0D                    dcr  c
0112: 79                    mov  a, c
0113: B1                    ora  c
0114: C2 08 01              jnz  loc_0108
0117: 78                    mov  a, b
0118: C1                    pop  b
0119: 47                    mov  b, a                       ; result in B
011A: C6 2F                 adi  2Fh                        ; perturb seed for next call
011C: 32 30 00              sta  rng_state
011F: F1                    pop  psw
0120: C9                    ret
                    ; BCD-add the 2-byte value at score_delta_lo/score_delta_hi to the
                    ; 2-byte score at score_lo/score_hi. If the final add carries, set
                    ; score_positive = 1 (score overflowed back to positive territory).
0121:               score_add:                              ; offset 0121h
0121: E5                    push h
0122: D5                    push d
0123: C5                    push b
0124: F5                    push psw
0125: 0E 02                 mvi  c, 02h                     ; 2 bytes
0127: 21 2B 00              lxi  h, score_lo
012A: 11 35 00              lxi  d, score_delta_lo
012D: 37                    stc
012E: 3F                    cmc                             ; CY = 0
012F:               loc_012F:
012F: 7E                    mov  a, m
0130: EB                    xchg
0131: 8E                    adc  m
0132: 27                    daa
0133: EB                    xchg
0134: 77                    mov  m, a
0135: F5                    push psw
0136: 79                    mov  a, c
0137: FE 01                 cpi  01h
0139: CA 3D 01              jz   loc_013D
013C: F1                    pop  psw
013D:               loc_013D:
013D: 0D                    dcr  c
013E: CA 46 01              jz   loc_0146
0141: 13                    inx  d
0142: 23                    inx  h
0143: C3 2F 01              jmp  loc_012F
0146:               loc_0146:
0146: F1                    pop  psw
0147: D2 4F 01              jnc  loc_014F
014A: 3E 01                 mvi  a, 01h
014C: 32 2F 00              sta  score_positive
014F:               loc_014F:
014F: F1                    pop  psw
0150: C1                    pop  b
0151: D1                    pop  d
0152: E1                    pop  h
0153: C9                    ret
                    ; BCD-subtract the 2-byte value at score_penalty_lo/score_penalty_hi
                    ; from score_lo/score_hi. If the final subtract produces no borrow
                    ; (i.e. score went negative), clear score_positive = 0 -- the game
                    ; shows "VY ZADOLZHALI GOSUDARSTVU" (you owe the state) in that case.
0154:               score_sub:                              ; offset 0154h
0154: E5                    push h
0155: D5                    push d
0156: C5                    push b
0157: F5                    push psw
0158: 11 2B 00              lxi  d, score_lo
015B: 21 37 00              lxi  h, score_penalty_lo
015E: 0E 02                 mvi  c, 02h
0160: 37                    stc
0161:               loc_0161:
0161: 3E 99                 mvi  a, 99h
0163: CE 00                 aci  00h
0165: 96                    sub  m
0166: EB                    xchg
0167: 86                    add  m
0168: 27                    daa
0169: 77                    mov  m, a
016A: F5                    push psw
016B: 79                    mov  a, c
016C: FE 01                 cpi  01h
016E: CA 72 01              jz   loc_0172
0171: F1                    pop  psw
0172:               loc_0172:
0172: EB                    xchg
0173: 0D                    dcr  c
0174: CA 7C 01              jz   loc_017C
0177: 13                    inx  d
0178: 23                    inx  h
0179: C3 61 01              jmp  loc_0161
017C:               loc_017C:
017C: F1                    pop  psw
017D: DA 84 01              jc   loc_0184
0180: AF                    xra  a
0181: 32 2F 00              sta  score_positive
0184:               loc_0184:
0184: F1                    pop  psw
0185: C1                    pop  b
0186: D1                    pop  d
0187: E1                    pop  h
0188: C9                    ret
                    ; Copy bytes from [DE] to [HL] until a NUL is read from [DE]. NUL is
                    ; NOT written to the destination.
0189:               str_copy_until_nul:                     ; offset 0189h
0189: 1A                    ldax d
018A: B7                    ora  a
018B: C8                    rz
018C: 77                    mov  m, a
018D: 13                    inx  d
018E: 23                    inx  h
018F: C3 89 01              jmp  str_copy_until_nul
0192: 77                    db   77h                        ; dead byte (fell through from rz)
                    ; Rising chirp: call monitor_beep with (B=09..13h, C=19..09h). Used
                    ; as a positive feedback cue when a diversant is destroyed.
0193:               beep_sweep_up:                          ; offset 0193h
0193: F5                    push psw
0194: C5                    push b
0195: D5                    push d
0196: 01 19 09              lxi  b, 0919h                   ; B=09h (duration), C=19h (period)
0199: 16 15                 mvi  d, 15h
019B:               loc_019B:
019B: C5                    push b
019C: CD 15 00              call monitor_beep
019F: C1                    pop  b
01A0: 04                    inr  b
01A1: 04                    inr  b
01A2: 0D                    dcr  c
01A3: 0D                    dcr  c
01A4: 78                    mov  a, b
01A5: BA                    cmp  d
01A6: DA 9B 01              jc   loc_019B
01A9: D1                    pop  d
01AA: C1                    pop  b
01AB: F1                    pop  psw
01AC: C9                    ret
                    ; Descending click: a short sweep used as the key-press feedback
                    ; inside get_key (called right after scan_kbd detects a key).
01AD:               beep_sweep_down:                        ; offset 01ADh
01AD: F5                    push psw
01AE: C5                    push b
01AF: D5                    push d
01B0: 01 09 20              lxi  b, 2009h
01B3: 16 09                 mvi  d, 09h
01B5:               loc_01B5:
01B5: C5                    push b
01B6: CD 15 00              call monitor_beep
01B9: C1                    pop  b
01BA: 0C                    inr  c
01BB: 05                    dcr  b
01BC: 05                    dcr  b
01BD: 78                    mov  a, b
01BE: BA                    cmp  d
01BF: D2 B5 01              jnc  loc_01B5
01C2: D1                    pop  d
01C3: C1                    pop  b
01C4: F1                    pop  psw
01C5: C9                    ret
                    ; Click per torpedo cell moved, ramping pitch upward. shoot_beep_freq
                    ; persists across calls so a long torpedo flight is a rising sweep.
01C6:               beep_shoot:                             ; offset 01C6h
01C6: F5                    push psw
01C7: C5                    push b
01C8: 3A 3B 00              lda  shoot_beep_freq
01CB: 47                    mov  b, a
01CC: 0E 08                 mvi  c, 08h
01CE: 3C                    inr  a
01CF: 32 3B 00              sta  shoot_beep_freq
01D2: CD 15 00              call monitor_beep
01D5: C1                    pop  b
01D6: F1                    pop  psw
01D7: C9                    ret
                    ; Fixed low-pitched tone played when a diversant is hit.
01D8:               beep_kill:                              ; offset 01D8h
01D8: F5                    push psw
01D9: C5                    push b
01DA: 06 B0                 mvi  b, 0B0h
01DC: 0E 08                 mvi  c, 08h
01DE: CD 15 00              call monitor_beep
01E1: C1                    pop  b
01E2: F1                    pop  psw
01E3: C9                    ret
                    ; Blocking keyboard read. Plays a click on every press, Ctrl-C bails
                    ; out to the monitor prompt, РУС/ЛАТ (0FEh) flips letter_case_mask,
                    ; and for any letter key (>= 40h) the case mask is XOR'd in so the
                    ; caller sees a consistent lowercase code regardless of case.
01E4:               get_key:                                ; offset 01E4h
01E4: C5                    push b
01E5: 3A 3C 00              lda  letter_case_mask
01E8: 4F                    mov  c, a
01E9:               loc_01E9:
01E9: CD 03 00              call monitor_scan_kbd
01EC: FE FF                 cpi  0FFh                       ; no key yet -> keep polling
01EE: CA E9 01              jz   loc_01E9
01F1: CD AD 01              call beep_sweep_down            ; key-press click
01F4: FE 03                 cpi  03h                        ; Ctrl-C: back to monitor
01F6: CA 12 00              jz   monitor_prompt
01F9: FE FE                 cpi  0FEh                       ; РУС/ЛАТ: toggle case mask
01FB: CA 10 02              jz   get_key_toggle_case
01FE: FE 40                 cpi  40h
0200: DA 04 02              jc   loc_0204
0203: A9                    xra  c                          ; letter -> apply case mask
0204:               loc_0204:
0204: 47                    mov  b, a
0205:               loc_0205:
0205: CD 03 00              call monitor_scan_kbd           ; wait for key release
0208: FE FF                 cpi  0FFh
020A: C2 05 02              jnz  loc_0205
020D: 78                    mov  a, b
020E: C1                    pop  b
020F: C9                    ret
0210:               get_key_toggle_case:                    ; offset 0210h
0210: 3A 3C 00              lda  letter_case_mask
0213: EE 20                 xri  20h
0215: 32 3C 00              sta  letter_case_mask
0218: 4F                    mov  c, a
